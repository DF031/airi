OPENAI_API_KEY=
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
CHAT_PROVIDER=zhipu
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
CHAT_MODEL=GLM-4-Flash-250414
EMBEDDING_MODEL=text-embedding-v2
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/

DASHSCOPE_API_KEY=
TTS_MODEL=edge-tts
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+8%
TTS_CACHE_DIR=data/tts_cache
VITE_LIVE2D_MODEL_URL=/live2d/hiyori/Hiyori.model3.json

RAG_STRATEGY=portable_v4
KNOWLEDGE_DIR=experiments/rag_reproduction/data
INDEX_ROOT=data/indexes
PORTABLE_RAG_CONFIG=experiments/rag_reproduction/configs/portable_rag.yaml
PORTABLE_RAG_TOP_K=8
PORTABLE_RAG_INIT_TIMEOUT_SEC=240
MEMORY_DB_PATH=data/memory/airi_memory_local.sqlite3

RETRIEVAL_TOP_K=4
RETRIEVAL_TIMEOUT_SEC=60
LLM_TIMEOUT_SEC=30
LLM_RATE_LIMIT_RETRIES=3
LLM_RATE_LIMIT_BACKOFF_SEC=8
LLM_RATE_LIMIT_MAX_BACKOFF_SEC=30
CHUNK_SIZE=600
CHUNK_OVERLAP=100

ENABLE_MEMORY_EXTRACTION=true
ENABLE_HYDE=true
ENABLE_CRAG_JUDGE=false
ENABLE_LLM_ACTIONS=false
CORS_ORIGINS=*
